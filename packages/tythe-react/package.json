{
  "name": "@tythe/react",
  "version": "0.1.1",
  "description": "React hooks (useQuery, useMutation, useSubscription) on top of TanStack Query for Tythe-generated clients.",
  "keywords": [
    "python",
    "react",
    "react-query",
    "rpc",
    "sse",
    "streaming",
    "tanstack-query",
    "tythe"
  ],
  "homepage": "https://github.com/tamimbinhakim/tythe#readme",
  "bugs": {
    "url": "https://github.com/tamimbinhakim/tythe/issues"
  },
  "license": "MIT",
  "author": "Tamim Bin Hakim (@tamimbinhakim)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/tythe.git",
    "directory": "packages/tythe-react"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "devDependencies": {
    "@tanstack/react-query": "5.100.10",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@tythe/ts": "workspace:*",
    "happy-dom": "20.9.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tsup": "8.5.1",
    "vite": "8.0.12",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0 <6",
    "@tythe/ts": "workspace:*",
    "react": ">=18.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
