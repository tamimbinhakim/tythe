{
  "name": "@tythe/ts",
  "version": "0.1.1",
  "description": "Tiny TypeScript runtime imported by Tythe-generated client.ts files.",
  "keywords": [
    "python",
    "rpc",
    "sse",
    "streaming",
    "trpc",
    "typescript",
    "tythe"
  ],
  "homepage": "https://github.com/tamimbinhakim/tythe#readme",
  "bugs": {
    "url": "https://github.com/tamimbinhakim/tythe/issues"
  },
  "license": "MIT",
  "author": "Tamim Bin Hakim (@tamimbinhakim)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/tythe.git",
    "directory": "packages/tythe-ts"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./sse": {
      "types": "./dist/sse.d.ts",
      "import": "./dist/sse.js",
      "require": "./dist/sse.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "25.7.0",
    "tsup": "8.5.1",
    "vite": "8.0.12",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=20"
  }
}
