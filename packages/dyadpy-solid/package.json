{
  "name": "@dyadpy/solid",
  "version": "0.1.0-alpha.0",
  "description": "SolidJS resource bindings (query, mutation, subscription) for Dyadpy-generated clients.",
  "keywords": [
    "python",
    "rpc",
    "solid",
    "solidjs",
    "sse",
    "streaming",
    "dyadpy"
  ],
  "homepage": "https://github.com/tamimbinhakim/dyadpy#readme",
  "bugs": {
    "url": "https://github.com/tamimbinhakim/dyadpy/issues"
  },
  "license": "MIT",
  "author": "Tamim Bin Hakim (@tamimbinhakim)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/dyadpy.git",
    "directory": "packages/dyadpy-solid"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "25.9.0",
    "@dyadpy/ts": "workspace:*",
    "happy-dom": "20.9.0",
    "solid-js": "1.9.13",
    "tsup": "8.5.1",
    "vite": "8.0.13",
    "vite-plugin-solid": "2.11.12",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "@dyadpy/ts": "workspace:*",
    "solid-js": ">=1.8.0 <2"
  },
  "engines": {
    "node": ">=20"
  }
}
